    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "graphql": "^16.11.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0-rc.2",
    "zod": "^3.23.8"
